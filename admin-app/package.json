{
  "name": "karagroup-admin",
  "version": "1.0.0",
  "description": "KaraGroup Admin Panel",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:win": "electron-vite build && electron-builder --win --x64",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:all": "electron-vite build && electron-builder --win --x64 --mac"
  },
  "dependencies": {
    "@tiptap/react": "^2.9.0",
    "@tiptap/pm": "^2.9.0",
    "@tiptap/starter-kit": "^2.9.0",
    "@tiptap/extension-underline": "^2.9.0",
    "@tiptap/extension-link": "^2.9.0",
    "@tiptap/extension-image": "^2.9.0",
    "@tiptap/extension-text-align": "^2.9.0",
    "@tiptap/extension-placeholder": "^2.9.0",
    "axios": "^1.7.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^32.1.2",
    "electron-builder": "^25.1.7",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.karagroup.admin",
    "productName": "KaraGroup Admin",
    "directories": { "output": "dist-electron" },
    "files": ["out/**/*"],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "dir", "arch": ["x64", "arm64"] }
      ],
      "icon": "resources/icon.icns"
    }
  }
}
